# Backend URL - Cambiar según el entorno
# Desarrollo local: http://127.0.0.1:8000
# Ngrok (desarrollo remoto): https://tu-url-ngrok.ngrok-free.dev
# Producción: https://tu-backend-produccion.com
VITE_BACKEND_URL=http://127.0.0.1:8000

# App URLs - para deep linking y OAuth callbacks
# Web development
VITE_APP_URL_DEV=http://localhost:8080
# Mobile app deep link scheme
VITE_APP_DEEPLINK_SCHEME=pawtalk
# Production URLs (cuando esté en Google Play/App Store)
VITE_APP_URL_PROD=https://pawtalk.app
# URL para OAuth callbacks (puede apuntar a backend o a app directamente)
VITE_OAUTH_CALLBACK_URL=http://localhost:8080/auth/callback
